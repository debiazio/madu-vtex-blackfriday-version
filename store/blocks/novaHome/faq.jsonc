    ]
  },
  "rich-text#content-beneficiosPrincipais-novaHome": {
    "props": {
      "blockClass": "content-faq-maduset",
      "text": "#### Nossos móveis são produzidos com materiais de alta resistência, desenvolvidos para oferecer longa vida útil, fácil higienização e excelente acabamento, ideais para ambientes que exigem altos padrões de limpeza."
    }
  },
