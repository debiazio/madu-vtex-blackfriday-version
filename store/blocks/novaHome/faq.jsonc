  "rich-text#trigger-podeSerPersonalizada-novaHome": {
    "props": {
      "blockClass": "text-trigger-faq-madu",
      "text": "### Os móveis são indicados apenas para hospitais?"
    }
  },
  "disclosure-content#podeSerPersonalizada-novaHome": {
    "props": {
      "blockClass": "content-faq-maduset"
    },
    "children": [
