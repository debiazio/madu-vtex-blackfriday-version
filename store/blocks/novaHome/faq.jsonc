  "rich-text#trigger-oqEhMadu-novaHome": {
    "props": {
      "blockClass": "text-trigger-faq-madu",
      "text": "### O que é a MAD.U?"
    }
  },
  "disclosure-content#oqEhMadu-novaHome": {
    "props": {
      "blockClass": "content-faq-maduset"
    },
    "children": [
      "rich-text#content-oqEhMadu-novaHome"
    ]
  },
  "rich-text#content-oqEhMadu-novaHome": {
    "props": {
      "blockClass": "content-faq-maduset",
      "text": "#### A MAD.U desenvolve mobiliário modular de alta qualidade para hospitais, clínicas, consultórios, laboratórios, farmácias, veterinárias, estéticas, escritórios e diversos outros ambientes profissionais. Nossos produtos combinam durabilidade, higiene, organização e personalização."
    }
  },
  "disclosure-layout#paraQuaisSegmentos-novaHome": {
    "props": {
      "blockClass": "layout-faq-maduset"
    },
    "children": [
      "disclosure-trigger#paraQuaisSegmentos-novaHome",
      "disclosure-content#paraQuaisSegmentos-novaHome"
    ]
  },
  "disclosure-trigger#paraQuaisSegmentos-novaHome": {
    "props": {
      "blockClass": "trigger-faq-maduset"
    },
    "children": [
      "rich-text#trigger-paraQuaisSegmentos-novaHome",
      "disclosure-state-indicator#configSet-maduset"
    ]
  },
  "rich-text#trigger-paraQuaisSegmentos-novaHome": {
    "props": {
      "blockClass": "text-trigger-faq-madu",
      "text": "### Os produtos podem ser personalizados?"
    }
  },
  "disclosure-content#paraQuaisSegmentos-novaHome": {
    "props": {
      "blockClass": "content-faq-maduset"
    },
    "children": [
      "rich-text#content-paraQuaisSegmentos-novaHome"
    ]
  },
  "rich-text#content-paraQuaisSegmentos-novaHome": {
    "props": {
      "blockClass": "content-faq-maduset",
      "text": "#### Sim. Grande parte dos produtos da MAD.U é modular e permite diversas configurações de gavetas, acessórios, cores e opcionais, conforme a necessidade de cada projeto."
    }
  },
  "disclosure-layout#beneficiosPrincipais-novaHome": {
