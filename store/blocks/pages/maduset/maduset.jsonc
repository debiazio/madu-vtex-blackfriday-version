  // o que é
  "disclosure-layout#oqEhMaduset-maduset": {
    "props": {
      "blockClass": "layout-faq-maduset"
    },
    "children": [
      "disclosure-trigger#oqEhMaduSet-maduset",
      "disclosure-content#oqEhMaduSet-maduset"
    ]
  },
  "disclosure-trigger#oqEhMaduSet-maduset": {
    "props": {
      "blockClass": "trigger-faq-maduset"
    },
    "children": [
      "rich-text#trigger-oqEhMaduSet-maduset",
      "disclosure-state-indicator#configSet-maduset"
    ]
  },
  "rich-text#trigger-oqEhMaduSet-maduset": {
    "props": {
      "blockClass": "text-trigger-faq-madu",
      "text": "### O que é a MAD.U SET?"
    }
  },
  "disclosure-content#oqEhMaduSet-maduset": {
    "props": {
      "blockClass": "content-faq-maduset"
    },
    "children": [
      "rich-text#content-oqEhMaduSet-maduset"
    ]
  },
  "rich-text#content-oqEhMaduSet-maduset": {
    "props": {
      "blockClass": "content-faq-maduset",
      "text": "#### A MAD.U SET é uma solução inteligente para organização, identificação e armazenamento de medicamentos, insumos e materiais. Seu sistema modular permite personalizar a organização conforme a necessidade de cada ambiente, proporcionando mais praticidade, segurança e agilidade na rotina."
    }
  },
  // para quais segmentos
  "disclosure-layout#paraQuaisSegmentos-maduset": {
    "props": {
      "blockClass": "layout-faq-maduset"
    },
    "children": [
      "disclosure-trigger#paraQuaisSegmentos-maduset",
      "disclosure-content#paraQuaisSegmentos-maduset"
    ]
  },
  "disclosure-trigger#paraQuaisSegmentos-maduset": {
    "props": {
      "blockClass": "trigger-faq-maduset"
    },
    "children": [
      "rich-text#trigger-paraQuaisSegmentos-maduset",
      "disclosure-state-indicator#configSet-maduset"
    ]
  },
  "rich-text#trigger-paraQuaisSegmentos-maduset": {
    "props": {
      "blockClass": "text-trigger-faq-madu",
      "text": "### Para quais segmentos a MAD.U SET é indicada?"
    }
  },
  "disclosure-content#paraQuaisSegmentos-maduset": {
    "props": {
      "blockClass": "content-faq-maduset"
    },
    "children": [
      "rich-text#content-paraQuaisSegmentos-maduset"
    ]
  },
  "rich-text#content-paraQuaisSegmentos-maduset": {
    "props": {
      "blockClass": "content-faq-maduset",
      "text": "#### A MAD.U SET pode ser utilizada em hospitais, clínicas, consultórios, laboratórios, farmácias, centros de estética, veterinárias, home care e diversos ambientes que necessitam de organização eficiente de medicamentos e materiais."
    }
  },
  // FAQ - Benefícios da MAD.U SET
  "disclosure-layout#beneficiosPrincipais-maduset": {
    "props": {
      "blockClass": "layout-faq-maduset"
    },
    "children": [
      "disclosure-trigger#beneficiosPrincipais-maduset",
      "disclosure-content#beneficiosPrincipais-maduset"
    ]
  },
  "disclosure-trigger#beneficiosPrincipais-maduset": {
    "props": {
      "blockClass": "trigger-faq-maduset"
    },
    "children": [
      "rich-text#trigger-beneficiosPrincipais-maduset",
      "disclosure-state-indicator#configSet-maduset"
    ]
  },
  "rich-text#trigger-beneficiosPrincipais-maduset": {
    "props": {
      "blockClass": "text-trigger-faq-madu",
      "text": "### Quais são os principais benefícios da MAD.U SET?"
    }
  },
  "disclosure-content#beneficiosPrincipais-maduset": {
    "props": {
      "blockClass": "content-faq-maduset"
    },
    "children": [
      "rich-text#content-beneficiosPrincipais-maduset"
    ]
  },
  "rich-text#content-beneficiosPrincipais-maduset": {
    "props": {
      "blockClass": "content-faq-maduset",
      "text": "#### Entre os principais benefícios estão: \n\n- Organização visual inteligente; \n- Agilidade na localização dos itens; \n- Redução de erros operacionais; \n- Melhor aproveitamento do espaço; \n- Facilidade de reposição e controle; \n- Sistema modular e personalizável; \n- Material resistente e de alta durabilidade."
    }
  },
  // FAQ - Personalização da MAD.U SET
  "disclosure-layout#podeSerPersonalizada-maduset": {
    "props": {
      "blockClass": "layout-faq-maduset"
    },
    "children": [
      "disclosure-trigger#podeSerPersonalizada-maduset",
      "disclosure-content#podeSerPersonalizada-maduset"
    ]
  },
  "disclosure-trigger#podeSerPersonalizada-maduset": {
    "props": {
      "blockClass": "trigger-faq-maduset"
    },
    "children": [
      "rich-text#trigger-podeSerPersonalizada-maduset",
      "disclosure-state-indicator#configSet-maduset"
    ]
  },
  "rich-text#trigger-podeSerPersonalizada-maduset": {
    "props": {
      "blockClass": "text-trigger-faq-madu",
      "text": "### A MAD.U SET pode ser personalizada?"
    }
  },
  "disclosure-content#podeSerPersonalizada-maduset": {
    "props": {
      "blockClass": "content-faq-maduset"
    },
    "children": [
      "rich-text#content-podeSerPersonalizada-maduset"
    ]
  },
  "rich-text#content-podeSerPersonalizada-maduset": {
    "props": {
      "blockClass": "content-faq-maduset",
      "text": "#### Sim. Os módulos e organizadores podem ser configurados de acordo com a necessidade de cada operação, permitindo criar soluções específicas para diferentes fluxos de trabalho."
    }
  },
