    }
  },
  "flex-layout.row#linha-listaCaracteristicasMaduset-maduset": {
    "props": {
      "blockClass": "linha-listaCaracteristicasMaduset-maduset",
      "colSizing": "auto",
      "preventHorizontalStretch": true
    },
    "children": [
      "flex-layout.row#iconeTexto-listaCarac1-maduset",
      "flex-layout.row#iconeTexto-listaCarac2-maduset",
      "flex-layout.row#iconeTexto-listaCarac3-maduset",
      "flex-layout.row#iconeTexto-listaCarac4-maduset",
      "flex-layout.row#iconeTexto-listaCarac5-maduset"
    ]
  },
  "flex-layout.row#iconeTexto-listaCarac1-maduset": {
    "props": {
      "blockClass": [
        "iconeTexto-lista-maduset",
        "carac1-maduset"
      ],
      "colSizing": "equal",
      "preventHorizontalStretch": true,
      "preventVerticalStretch": true
    },
    "children": [
      "image#durabilidade-maduset",
      "rich-text#durabilidade-maduset"
    ]
  },
  "image#durabilidade-maduset": {
    "props": {
      "blockClass": "image-lista-maduset",
      "src": "https://madumfm2.vtexassets.com/assets/vtex.file-manager-graphql/images/f95030b7-43b1-4961-8af7-b715a83bcdd5___e1281c994084d6511e0fdf7d5ccd3379.webp",
      "alt": "Alta durabilidade"
    }
  },
