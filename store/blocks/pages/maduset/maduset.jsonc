  },
  "flex-layout.row#linhaText-ErrosAcontecem-maduset": {
    "props": {
      "blockClass": "linhaText-ErrosAcontecem-maduset",
      "width": "50%"
    },
    "children": [
      "rich-text#titulo-ErrosAcontecem-maduset",
      "rich-text#subtitulo-ErrosAcontecem-maduset"
    ]
  },
  "rich-text#titulo-ErrosAcontecem-maduset": {
    "props": {
      "blockClass": "titulo-ErrosAcontecem-maduset",
      "text": "## Quando a \n ## **organização** \n ## **não acompanha** \n ## a operação, os \n ## **erros aparecem**."
    }
