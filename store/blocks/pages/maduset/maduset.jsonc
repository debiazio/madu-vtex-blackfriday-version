  // -----------------------------------
  // liberdade
  // -----------------------------------
  "flex-layout.row#linhaLiberdadeOrganizar": {
    "props": {
      "blockClass": "linha-liberdade-maduset",
      "colSizing": "auto"
    },
    "children": [
      "flex-layout.row#titulo-liberdade-maduset",
      "flex-layout.row#imgs-liberdade-maduset"
    ]
  },
  "flex-layout.row#titulo-liberdade-maduset": {
    "props": {
      "blockClass": "linha-titulo-liberdade-maduset"
    },
    "children": [
      "rich-text#titulo-liberdade-maduset"
    ]
  },
  "rich-text#titulo-liberdade-maduset": {
    "props": {
      "text": "## Para quem quer \n ## **liberdade total para organizar**",
      "blockClass": "titulo-liberdade-maduset",
      "textPosition": "CENTER",
      "textAlignment": "CENTER"
    }
  },
  "flex-layout.row#imgs-liberdade-maduset": {
    "props": {
      "blockClass": "imgs-liberdade-maduset"
    },
    "children": [
      "responsive-layout.desktop#imgs-liberdade-maduset",
      "responsive-layout.mobile#imgs-liberdade-maduset"
    ]
  },
  "responsive-layout.desktop#imgs-liberdade-maduset": {
    "children": [
      "image#imgs-liberdade-maduset"
    ]
  },
  "image#imgs-liberdade-maduset": {
    "props": {
      "blockClass": "imageDesktop-liberdade-maduset",
      "alt": "Produtos liberdade desktop",
