    "children": [
      "image#imgsMobile-liberdade-maduset"
    ]
  },
  "image#imgsMobile-liberdade-maduset": {
    "props": {
      "blockClass": "imageMobile-liberdade-maduset",
      "alt": "Produtos liberdade mobile",
