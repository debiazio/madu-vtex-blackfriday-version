    }
  },
  // -----------------------------------
  // liberdade
  // -----------------------------------
  "flex-layout.row#linhaLiberdadeOrganizar": {
    "props": {
      "blockClass": "linha-liberdade-maduset",
      "colSizing": "auto"
    },
    "children": [
      "flex-layout.row#titulo-liberdade-maduset",
      "flex-layout.row#imgs-liberdade-maduset"
    ]
  },
  "flex-layout.row#titulo-liberdade-maduset": {
    "props": {
      "blockClass": "linha-titulo-liberdade-maduset"
    },
    "children": [
      "rich-text#titulo-liberdade-maduset"
    ]
  },
  "rich-text#titulo-liberdade-maduset": {
    "props": {
      "text": "## Para quem quer \n ## **liberdade total para organizar**",
      "blockClass": "titulo-liberdade-maduset",
      "textPosition": "CENTER",
      "textAlignment": "CENTER"
    }
  },
  "flex-layout.row#imgs-liberdade-maduset": {
    "props": {
      "blockClass": "imgs-liberdade-maduset"
    },
    "children": [
      "responsive-layout.desktop#imgs-liberdade-maduset",
      "responsive-layout.mobile#imgs-liberdade-maduset"
    ]
  },
  "responsive-layout.desktop#imgs-liberdade-maduset": {
    "children": [
      "image#imgs-liberdade-maduset"
    ]
  },
  "image#imgs-liberdade-maduset": {
    "props": {
      "blockClass": "imageDesktop-liberdade-maduset",
      "alt": "Produtos liberdade desktop",
      "src": "https://madumfm2.vtexassets.com/assets/vtex.file-manager-graphql/images/f165beec-a4b2-4faa-8b82-120a289611d1___45a72acd6636e5b46c9097d65c68874d.webp"
    }
  },
  "responsive-layout.mobile#imgs-liberdade-maduset": {
    "children": [
      "image#imgsMobile-liberdade-maduset"
    ]
  },
  "image#imgsMobile-liberdade-maduset": {
    "props": {
      "blockClass": "imageMobile-liberdade-maduset",
      "alt": "Produtos liberdade mobile",
      "src": "https://madumfm2.vtexassets.com/assets/vtex.file-manager-graphql/images/6cb937e1-fcac-4f8e-8fc1-522a41229f7f___13ffa47f4875c110309f255775533498.webp"
    }
  },
  // ----------------------------------------
  // disclosure - como configurar
  // ----------------------------------------
  // ÍCONE DO DISCLOSURE
  "disclosure-state-indicator#configSet-maduset": {
    "props": {
      "Show": "icon-caret#down-configSet-maduset",
      "Hide": "icon-caret#up-configSet-maduset"
    }
  },
  "icon-caret#down-configSet-maduset": {
    "props": {
      "blockClass": "caret-baixo-maduset",
      "orientation": "down"
    }
  },
  "icon-caret#up-configSet-maduset": {
    "props": {
      "blockClass": "cima-configSet-maduset",
      "orientation": "up"
    }
  },
  "flex-layout.row#linhaDisclosure-comoXonfig-maduset": {
    "props": {
      "blockClass": "linhaDisclosure-comoXonfig-maduset",
      "fullWidth": true,
      "colSizing": "auto"
    },
    "children": [
      "flex-layout.row#textos-comoConfig-maduset",
      "flex-layout.row#disclosure-comoConfig-maduset"
    ]
  },
  "flex-layout.row#textos-comoConfig-maduset": {
    "props": {
      "blockClass": "comoConfig-maduset"
    },
    "children": [
      "rich-text#tituloComoConfig-maduset",
      "rich-text#subTituloComoConfig-maduset"
    ]
  },
  "rich-text#tituloComoConfig-maduset": {
    "props": {
      "text": "## COMO **CONFIGURAR**?",
      "blockClass": "titulo-liberdade-maduset",
      "textPosition": "CENTER",
      "textAlignment": "CENTER"
    }
  },
  "rich-text#subTituloComoConfig-maduset": {
    "props": {
      "text": "Monte seu MADU SET em 4 etapas",
      "blockClass": "subtitulo-comoConfig-maduset",
      "textPosition": "CENTER",
      "textAlignment": "CENTER"
    }
  },
  "flex-layout.row#disclosure-comoConfig-maduset": {
    "props": {
      "blockClass": "disclosure-comoConfig-maduset",
      "colSizing": "auto"
    },
    "children": [
      "disclosure-layout-group#comoConfig-maduset"
    ]
  },
  "disclosure-layout-group#comoConfig-maduset": {
    "props": {
      "blockClass": "group-comoConfig-maduset"
    },
    "children": [
      "disclosure-layout#tamanhoBases-maduset",
      "disclosure-layout#openSets-maduset",
      "disclosure-layout#coresSet-maduset",
      "disclosure-layout#gravacaoPersonalizada-maduset"
    ]
  },
  // tamanho base
  "disclosure-layout#tamanhoBases-maduset": {
    "props": {
      "blockClass": "layout-comoConfig-maduset"
    },
    "children": [
      "disclosure-trigger#tamanhoBases-maduset",
      "disclosure-content#tamanhoBases-maduset"
    ]
  },
  "disclosure-trigger#tamanhoBases-maduset": {
    "props": {
      "blockClass": "trigger-comoConfig-maduset"
    },
    "children": [
      "rich-text#trigger-tamanhoBases-maduset",
      "disclosure-state-indicator#configSet-maduset"
    ]
  },
  "disclosure-content#tamanhoBases-maduset": {
    "props": {
      "blockClass": "content-comoConfig-maduset"
    },
    "children": [
      "image#img1content-openSets-maduset",
      "image#img2content-openSets-maduset",
      "image#img3content-openSets-maduset",
      "image#img4content-openSets-maduset",
      "image#img5content-openSets-maduset",
      "image#img6content-openSets-maduset",
      "image#img7content-openSets-maduset",
      "image#img8content-openSets-maduset"
    ]
  },
  "rich-text#trigger-tamanhoBases-maduset": {
    "props": {
      "blockClass": "texto-trigger-comoConfig-maduset",
      "text": "**1** Escolha o tamanho das bases"
    }
  },
  "image#img1content-openSets-maduset": {
    "props": {
      "blockClass": "img-modulosDisclosure-maduset",
      "alt": "1Modulos",
      "src": "https://madumfm2.vtexassets.com/assets/vtex.file-manager-graphql/images/4fc72814-ecc7-49b9-bd7a-a911b8268e01___5854bf35f7056fe7eaf57094974ae8b6.webp"
    }
  },
  "image#img2content-openSets-maduset": {
    "props": {
