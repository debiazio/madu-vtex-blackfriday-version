      "rich-text#escalabilidade-maduset"
    ]
  },
  "image#escalabilidade-maduset": {
    "props": {
      "blockClass": "image-lista-maduset",
      "src": "https://madumfm2.vtexassets.com/assets/vtex.file-manager-graphql/images/dd79da0c-46d1-4e81-a69d-21ab31ade0d6___c1d9d4c8db4c0210489119d2f6731eba.webp",
      "alt": "Escalabilidade"
    }
  },
